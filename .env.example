# ==========================================================================
# TEMPLATE DE CONFIGURAÇÕES (TEMPLATE.env)
# ==========================================================================
# Este arquivo serve como um guia de quais informações o sistema precisa.
# ⚠️ NÃO COLOQUE SENHAS REAIS AQUI. 
# -> Copie este arquivo, renomeie para '.env' e preencha lá.
# ==========================================================================

# --- 1. CONFIGURAÇÕES DO DJANGO ---
DEBUG=True
SECRET_KEY='gerada-automaticamente-pelo-setup'
ALLOWED_HOSTS=*

# --- 2. BANCO DE DADOS LOCAL (MYSQL) ---
# Usado para armazenar usuários do portal e configurações do sistema.
DB_NAME='portal_ggci'
DB_USER='portal_user'
DB_PASSWORD='sua_senha_local'
DB_HOST='127.0.0.1'
DB_PORT='3306'

# --- 3. DASHBOARD POLICHAT ---
# Credenciais para extração automática de dados do painel Polichat.
DASHBOARD_POLICHAT_USER='seu_email@ovg.org.br'
DASHBOARD_POLICHAT_PASS='sua_senha'

# --- 4. PORTAL PBU (GOVERNO) ---
# O Portal PBU possui dois níveis de acesso diferentes usados pela IA.
PORTAL_PBU_USER='seu_usuario'
PORTAL_PBU_PASS_ANALISE_IA='senha_para_analise_ia'
PORTAL_PBU_PASS_PAGAMENTOS='senha_para_pagamentos'

# --- 5. BANCO DE DADOS EXTERNO (SIBU) ---
# Conexão direta com o banco de dados oficial SIBU para auditoria.
SIBU_BANCO_DADOS_HOST='10.237.1.16'
SIBU_BANCO_DADOS_USER='bi_ovg'
SIBU_BANCO_DADOS_PASS='bi_ovg@#$124as65'
SIBU_BANCO_DADOS_NAME='sibu'
