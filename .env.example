# ==========================================================================
# CONFIGURAÇÕES DE AMBIENTE (PORTAL GGCI)
# ==========================================================================

# MODO DE DEPURAÇÃO:
# True: Mostra telas de erro amarelas (apenas para desenvolvimento).
# False: Oculta detalhes do erro (Obrigatório em Produção).
DEBUG=True

# CHAVE CRIPTOGRÁFICA MESTRE DO DJANGO
# Em produção, crie uma chave aleatória e segura. Não use a do ambiente local.
SECRET_KEY='sua_chave_secreta_aqui'

# CREDENCIAIS DO BANCO DE DADOS
# Os valores abaixo devem coincidir com os gerados pelo script 'setup.sh'
DB_NAME='portal_ggci'
DB_USER='root'
DB_PASSWORD='sua_senha_do_banco_aqui'
DB_HOST='127.0.0.1'
DB_PORT='3306'

# ALLOWED_HOSTS
# IPs e domínios permitidos, separados por vírgula. Ex: 192.168.0.10,ovg.org.br
ALLOWED_HOSTS=*
